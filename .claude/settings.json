{
  "$comment": "Claude Code Settings. Doku: https://docs.claude.com/en/docs/claude-code/settings",
  "permissions": {
    "allow": [
      "Bash(git status)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(npm test:*)",
      "Bash(npm run:*)",
      "Read",
      "Edit",
      "Write"
    ],
    "deny": [
      "Bash(rm -rf /:*)",
      "Bash(git push --force:*)",
      "Bash(git reset --hard:*)",
      "Read(.env*)",
      "Edit(.env*)",
      "Write(.env*)",
      "Read(.git/**)"
    ],
    "ask": [
      "Bash(git push:*)",
      "Bash(git commit:*)"
    ]
  },
  "$hooksExample": {
    "$note": "Hooks unten sind Beispiele. Zum Aktivieren in 'hooks' verschieben. Tool-Input kommt als JSON via stdin (NICHT als Env-Var) — via jq extrahieren. Doku: https://docs.claude.com/en/docs/claude-code/hooks",
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "command -v jq >/dev/null || exit 0; CMD=$(jq -r '.tool_input.command'); echo \"Ausgeführt: $CMD\" >> ~/.claude-bash.log"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "command -v jq >/dev/null && command -v prettier >/dev/null || exit 0; FILE=$(jq -r '.tool_input.file_path'); prettier --write \"$FILE\" 2>/dev/null || true"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "command -v jq >/dev/null || exit 0; PROMPT=$(jq -r '.prompt'); echo \"$(date -Iseconds) $PROMPT\" >> ~/.claude-prompts.log"
          }
        ]
      }
    ]
  },
  "hooks": {}
}
